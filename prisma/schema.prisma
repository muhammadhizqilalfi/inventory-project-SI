generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  ADMIN
  USER
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum QCStatus {
  PASSED
  FAILED
  NEEDS_INSPECTION
}

//////////////////////
// USER & SECURITY
//////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // e.g., "CREATE_PO", "PICKING_COMPLETED"
  details   String?  // Untuk Audit Trail mendalam
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// MASTER DATA
//////////////////////

model Category {
  id       String    @id @default(uuid())
  name     String
  products Product[]
}

model Product {
  id           String  @id @default(uuid())
  name         String
  barcode      String? @unique
  unit         String
  minStock     Int     @default(0) // Fitur: Low Stock Notification

  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  batches            Batch[]
  inventories        Inventory[]
  movements          StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  transferItems      StockTransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id             String          @id @default(uuid())
  name           String          @unique
  contact        String?
  address        String?
  purchaseOrders PurchaseOrder[]
}

model Warehouse {
  id        String            @id @default(uuid())
  name      String
  location  String
  locations StorageLocation[]
}

model StorageLocation {
  id          String  @id @default(uuid())
  warehouseId String
  zone        String?
  rack        String?
  bin         String?

  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  inventories Inventory[]

  transfersFrom StockTransfer[] @relation("FromLocation")
  transfersTo   StockTransfer[] @relation("ToLocation")
  movementsFrom StockMovement[] @relation("MoveFrom")
  movementsTo   StockMovement[] @relation("MoveTo")
}

//////////////////////
// INVENTORY
//////////////////////

model Inventory {
  id               String  @id @default(uuid())
  productId        String
  locationId       String
  batchId          String?
  quantity         Int     @default(0) // Stok Fisik
  reservedQuantity Int     @default(0) // Fitur: Stock Reservation (di-pick tapi belum dikirim)

  product     Product         @relation(fields: [productId], references: [id])
  location    StorageLocation @relation(fields: [locationId], references: [id])
  batch       Batch?          @relation(fields: [batchId], references: [id])
  opnameItems StockOpnameItem[]

  @@unique([productId, locationId, batchId])
}

model Batch {
  id          String      @id @default(uuid())
  productId   String
  expiryDate  DateTime?   // Fitur: FEFO & Expiry Monitoring
  batchNumber String?     @unique

  product     Product     @relation(fields: [productId], references: [id])
  inventories Inventory[]
}

//////////////////////
// INBOUND (Masuk)
//////////////////////

model PurchaseOrder {
  id         String              @id @default(uuid())
  supplierId String
  date       DateTime            @default(now())
  status     OrderStatus         @default(PENDING)
  items      PurchaseOrderItem[]
  receipts   GoodsReceipt[]

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  receivedQty     Int           @default(0) // Mendukung Inbound Parsial
  price           Decimal?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model GoodsReceipt {
  id            String             @id @default(uuid())
  poId          String
  date          DateTime           @default(now())
  status        OrderStatus
  items         GoodsReceiptItem[]

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
}

model GoodsReceiptItem {
  id             String       @id @default(uuid())
  goodsReceiptId String
  productId      String
  quantity       Int
  qcStatus       QCStatus     @default(NEEDS_INSPECTION) // Fitur: Quality Control

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
}

//////////////////////
// OUTBOUND (Keluar)
//////////////////////

model SalesOrder {
  id        String           @id @default(uuid())
  date      DateTime         @default(now())
  status    OrderStatus      @default(PENDING)
  items     SalesOrderItem[]
  shipments Shipment[]
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Int
  fulfilledQty Int        @default(0) // Mendukung Partial Shipment / Backorder

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
}

model Shipment {
  id           String   @id @default(uuid())
  salesOrderId String
  date         DateTime @default(now())
  trackingNo   String?

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
}

//////////////////////
// STOCK TRANSFER
//////////////////////

model StockTransfer {
  id             String              @id @default(uuid())
  fromLocationId String
  toLocationId   String
  status         OrderStatus         @default(PENDING)
  items          StockTransferItem[]
  createdAt      DateTime            @default(now())

  fromLocation StorageLocation @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   StorageLocation @relation("ToLocation", fields: [toLocationId], references: [id])
}

model StockTransferItem {
  id              String        @id @default(uuid())
  stockTransferId String
  productId       String
  quantity        Int

  transfer StockTransfer @relation(fields: [stockTransferId], references: [id])
  product  Product       @relation(fields: [productId], references: [id])
}

//////////////////////
// STOCK OPNAME
//////////////////////

model StockOpname {
  id     String            @id @default(uuid())
  date   DateTime          @default(now())
  status OrderStatus       @default(PENDING)
  items  StockOpnameItem[]
}

model StockOpnameItem {
  id            String      @id @default(uuid())
  stockOpnameId String
  inventoryId   String
  systemQty     Int         // Jumlah di aplikasi
  actualQty     Int         // Jumlah saat hitung fisik
  adjustmentQty Int         // Selisih untuk auto-adjustment

  stockOpname StockOpname @relation(fields: [stockOpnameId], references: [id])
  inventory   Inventory   @relation(fields: [inventoryId], references: [id])
}

//////////////////////
// STOCK MOVEMENT (Audit Trail Stok)
//////////////////////

model StockMovement {
  id             String       @id @default(uuid())
  productId      String
  fromLocationId String?
  toLocationId   String?
  type           MovementType
  quantity       Int
  referenceId    String?      // ID dari PO/SO/Transfer sebagai bukti
  date           DateTime     @default(now())

  product      Product          @relation(fields: [productId], references: [id])
  fromLocation StorageLocation? @relation("MoveFrom", fields: [fromLocationId], references: [id])
  toLocation   StorageLocation? @relation("MoveTo", fields: [toLocationId], references: [id])
}