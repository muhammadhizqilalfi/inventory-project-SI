generator client {
  provider = "prisma-client-js"
}

datasource inventra {
  provider  = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
}